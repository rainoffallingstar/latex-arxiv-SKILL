  author = {Chen, Mei},
  school = {University of [Name]},
  year   = {2022},
  type   = {PhD Dissertation},
  month  = {may},
  url    = {https://example.edu/handle/xxxx}
}

% Master's thesis example
@mastersthesis{smith2023thesis,
  title  = {Methods for [Topic] Analysis},
  author = {Smith, Robert},
