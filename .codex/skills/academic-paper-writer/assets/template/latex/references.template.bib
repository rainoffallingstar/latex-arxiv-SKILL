}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% MISC (for websites, software, datasets, etc.)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Required fields: author/title
% Optional fields: howpublished, month, year, note, url

@misc{example2023software,
  title        = {[Software Name]: A Tool for [Purpose]},
  author       = {Author, First and Author, Second and others},
  howpublished = {GitHub repository},
  year         = {2023},
  url          = {https://github.com/example/tool},
  note         = {Accessed: 2023-12-15}
}

% Dataset citation
@misc{example2009dataset,
  author       = {Author, First and Author, Second and Author, Third},
  title        = {[Dataset Name]: A Dataset for [Purpose]},
  howpublished = {International Conference on [Field]},
  year         = {2009},
  url          = {http://www.example-dataset.org/}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TIPS FOR BIBTEXT ENTRIES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% 1. Always use consistent citation keys (e.g., firstauthorYEARfirstword)
% 2. Include DOIs and URLs whenever available
% 3. Use proper capitalization in titles (BibTeX will handle case conversion)
% 4. For author names, use format: "Last Name, First Name"
% 5. Separate multiple authors with "and"
% 6. Use curly braces {} to protect capitalization, e.g., {DNA}, {RNA}, {pH}
% 7. For conference papers, include the full name of the conference
% 8. For arXiv papers, include both the arXiv identifier and proper classification
% 9. Month fields should use three-letter abbreviations: jan, feb, mar, etc.
% 10. The "note" field is useful for additional information 
